<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource PlexDark}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource PlexDark}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource PlexText}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource PlexAccent}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource PlexDark}" />
        <Setter Property="BarTextColor" Value="{StaticResource PlexText}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PlexText}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource PlexText}" />
        <Setter Property="BackgroundColor" Value="{StaticResource PlexSurface}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource PlexMuted}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PlexAccent}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="14,10" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource PlexAccent}" />
    </Style>

    <Style x:Key="CardFrame" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource PlexCard}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="BorderColor" Value="Transparent" />
    </Style>

    <Style x:Key="HeaderLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PlexAccent}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="22" />
    </Style>

    <Style x:Key="SubheaderLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PlexTextSecondary}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="ScoreLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PlexSuccess}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="16" />
    </Style>

    <Style x:Key="RatingLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PlexOrange}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
    </Style>

</ResourceDictionary>
