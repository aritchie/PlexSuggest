<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PlexSuggest.Maui.ViewModels"
             xmlns:cfg="clr-namespace:PlexSuggest.Core.Configuration;assembly=PlexSuggest.Core"
             x:Class="PlexSuggest.Maui.Pages.ConfigPage"
             x:DataType="vm:ConfigViewModel"
             Title="PlexSuggest">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="16" MaximumWidthRequest="500"
                             HorizontalOptions="Center" VerticalOptions="Center">

            <Label Text="PlexSuggest"
                   Style="{StaticResource HeaderLabel}"
                   FontSize="32"
                   HorizontalOptions="Center" />

            <Label Text="Personalized recommendations from your Plex library"
                   Style="{StaticResource SubheaderLabel}"
                   HorizontalOptions="Center" />

            <BoxView HeightRequest="1" Color="{StaticResource PlexCard}" Margin="0,8" />

            <!-- ── Server List ── -->
            <VerticalStackLayout Spacing="12"
                                 IsVisible="{Binding ShowAddForm, Converter={StaticResource InvertedBoolConverter}}">

                <CollectionView ItemsSource="{Binding Servers}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="cfg:ServerEntry">
                            <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                                <Grid ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="4">
                                    <Label Text="{Binding Name}"
                                           FontFamily="OpenSansSemibold"
                                           FontSize="16"
                                           Grid.Row="0" Grid.Column="0" />

                                    <Label Text="{Binding Description}"
                                           Style="{StaticResource SubheaderLabel}"
                                           Grid.Row="1" Grid.Column="0" />

                                    <Label Text="{Binding ServerUrl}"
                                           TextColor="{StaticResource PlexMuted}"
                                           FontSize="12"
                                           Grid.Row="2" Grid.Column="0" />

                                    <Button Text="Connect"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ConfigViewModel}}, Path=ConnectToServerCommand}"
                                            CommandParameter="{Binding .}"
                                            WidthRequest="90"
                                            HeightRequest="36"
                                            Padding="8,4"
                                            FontSize="13"
                                            Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                                            VerticalOptions="Center" />

                                    <Button Text="X"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ConfigViewModel}}, Path=RemoveServerCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource PlexMuted}"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            Padding="0"
                                            FontSize="13"
                                            Grid.Row="0" Grid.Column="2" Grid.RowSpan="3"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Button Text="+ Add Server"
                        Command="{Binding ShowAddServerFormCommand}"
                        BackgroundColor="{StaticResource PlexCard}"
                        Margin="0,4,0,0" />

                <Button Text="Reset All"
                        Command="{Binding ResetAllCommand}"
                        BackgroundColor="{StaticResource PlexMuted}"
                        Margin="0,8,0,0" />
            </VerticalStackLayout>

            <!-- ── Add Server Form ── -->
            <VerticalStackLayout Spacing="12"
                                 IsVisible="{Binding ShowAddForm}">

                <Label Text="Server URL" Style="{StaticResource SubheaderLabel}" />
                <Entry Text="{Binding ServerUrl}"
                       Placeholder="http://192.168.1.100:32400"
                       Keyboard="Url" />

                <Label Text="Plex Token" Style="{StaticResource SubheaderLabel}" />
                <Entry Text="{Binding Token}"
                       Placeholder="Your Plex authentication token"
                       IsPassword="True" />

                <Label Text="Description" Style="{StaticResource SubheaderLabel}" />
                <Entry Text="{Binding Description}"
                       Placeholder="e.g. Home Server, Office" />

                <Button Text="Connect"
                        Command="{Binding AddServerCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        Margin="0,8,0,0" />

                <Button Text="Cancel"
                        Command="{Binding CancelAddServerCommand}"
                        BackgroundColor="{StaticResource PlexMuted}"
                        IsVisible="{Binding HasServers}" />
            </VerticalStackLayout>

            <!-- ── Shared Status ── -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />

            <Label Text="{Binding StatusMessage}"
                   Style="{StaticResource SubheaderLabel}"
                   HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
