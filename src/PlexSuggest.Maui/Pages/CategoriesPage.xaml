<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:PlexSuggest.Maui.ViewModels"
             xmlns:rec="clr-namespace:PlexSuggest.Core.Recommendations;assembly=PlexSuggest.Core"
             x:Class="PlexSuggest.Maui.Pages.CategoriesPage"
             x:DataType="vm:CategoriesViewModel"
             Title="{Binding SectionTitle}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="20">

        <Label Text="Categories"
               Style="{StaticResource HeaderLabel}"
               Margin="0,0,0,4" />

        <Label Grid.Row="1"
               Text="{Binding StatusMessage}"
               Style="{StaticResource SubheaderLabel}"
               Margin="0,0,0,12" />

        <CollectionView Grid.Row="2"
                         ItemsSource="{Binding Categories}"
                         SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="rec:Category">
                    <Frame Style="{StaticResource CardFrame}" Margin="0,4">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CategoriesViewModel}}, Path=SelectCategoryCommand}"
                                CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Name}" FontSize="17"
                                   FontFamily="OpenSansSemibold"
                                   TextColor="{StaticResource PlexAccent}" />
                            <Label Text="{Binding Description}"
                                   Style="{StaticResource SubheaderLabel}" />
                            <Label FontSize="12"
                                   TextColor="{StaticResource PlexMuted}">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} recommendations">
                                        <Binding Path="Items.Count" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.Row="3"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Margin="0,12" />

    </Grid>

</ContentPage>
